{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "0.10.3",
  "short_name": "__MSG_ext_short_name__",
  "description": "__MSG_ext_description__",
  "default_locale": "en",
  "author": "Jake Goldman, Partner at Fueled",
  "homepage_url": "https://github.com/WordPress/browser-extension",

  "action": {
    "default_title": "__MSG_ext_action_title__",
    "default_icon": {
      "16": "icons/icon-16-inactive.png",
      "32": "icons/icon-32-inactive.png"
    },
    "default_popup": "popup/popup.html"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/early.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/detect.js", "lib/rest.js", "lib/host.js", "lib/block-inspector.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "commands": {
    "edit-this-page": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "__MSG_cmd_edit_this_page__"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
