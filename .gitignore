node_modules/
CLAUDE.md
.claude/
.DS_Store
# preview harness is a dev-only artifact — rebuild locally with npm run build
dist/preview.*
# wp-scripts auxiliary output — unused by popup.html, not copied into the
# Chrome zip or Safari Resources
dist/*-rtl.css
dist/*.map
# release zips produced by scripts/package-chrome.sh — attach to GitHub Releases
release/
# Xcode — user-specific state only; the Safari project itself is committed
safari/**/xcuserdata/
safari/**/*.xcuserstate
safari/**/DerivedData/
safari/**/build/
# Xcode build output (DerivedData/intermediates) when the Safari project is
# built with its output directory set here — generated, never committed
safari-build/
# local migration scratch — referenced during the transfer to
# WordPress/browser-extension; not shipped to either repo
.transfer/
